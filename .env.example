# Конфигурация базы данных
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=bank_db
DB_SSL_MODE=disable

# Конфигурация сервера
SERVER_PORT=7556
SERVER_READ_TIMEOUT=10
SERVER_WRITE_TIMEOUT=10
SERVER_IDLE_TIMEOUT=120

# Конфигурация приложения
APP_ENV=development
LOG_LEVEL=info

# Конфигурация аутентификации
JWT_SECRET=your-super-secret-256-bit-jwt-key-change-this-in-production!
JWT_EXPIRE_HOURS=24

# Примечания:
# - Скопируйте этот файл в .env и укажите ваши настройки
# - ВАЖНО: .env файл не должен быть в git (добавьте его в .gitignore)
# - В production используйте сложные пароли и уникальный JWT_SECRET!